Closeable_MeaninglessClose() {

    event close before() :
        call(* Closeable+.close()) && ( target(ByteArrayInputStream) || target(ByteArrayOutputStream) || target(CharArrayWriter) || target(StringWriter) ) {
        			RVMLogging.out.println(Level.CRITICAL, __DEFAULT_MESSAGE);
        			RVMLogging.out.println(Level.CRITICAL, "close() has no effect.");
        }

}